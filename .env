# ============================================================
# ELITE AUCTION — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ---------------------------
# FRONTEND (Vite — must start with VITE_)
# ---------------------------
VITE_SOCKET_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001

# ---------------------------
# BACKEND — Server
# ---------------------------
PORT=3001

# Allowed CORS origin(s). Use comma-separated list for multiple.
# In production: https://yourdomain.com
# CORS_ORIGIN=http://localhost:5173

# ---------------------------
# BACKEND — Database
# ---------------------------
# MongoDB connection string (local or Atlas)
# MONGO_URI=mongodb://localhost:27017/auctionDB
# Example Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/auctionDB

# ---------------------------
# BACKEND — AI (Google Gemini)
# ---------------------------
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_google_gemini_api_key_here

# ---------------------------
# AUCTION SETTINGS (optional overrides)
# ---------------------------
# Timer in seconds for each player bid round
AUCTION_TIMER_SECONDS=60

# Maximum entries in room activity log
MAX_ACTIVITY_LOG=100

# Maximum chat messages kept in memory per room
MAX_MESSAGES=100

# Hours before an inactive room is marked as expired
ROOM_EXPIRY_HOURS=24
